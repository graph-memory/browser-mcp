{
  "name": "@graphmemory/browser-mcp",
  "version": "0.1.0",
  "description": "MCP server that gives AI agents a full browser — open pages, read content, click, type, scroll, take screenshots, manage tabs, and emulate devices.",
  "type": "module",
  "bin": {
    "browser-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "postinstall": "npx playwright install chromium"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "browser",
    "playwright",
    "automation",
    "scraping",
    "ai",
    "claude",
    "agent",
    "headless",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graph-memory/browser-mcp.git"
  },
  "author": "graph-memory",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "commander": "^14.0.3",
    "jsdom": "^29.0.2",
    "nanoid": "^5.1.7",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "turndown": "^7.2.4",
    "zod": "^4.3.6"
  },
  "license": "Elastic-2.0",
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
